# Copia este archivo como ".env" (sin .example) y rellena tus valores.
# Los encuentras en Supabase -> Settings -> API

# Project URL
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Project API keys -> anon public  (la PÚBLICA, no la service_role)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Número de WhatsApp para pedidos (formato internacional sin +, ej: 51938417243)
VITE_WHATSAPP_NUMERO=tu_numero_aqui
